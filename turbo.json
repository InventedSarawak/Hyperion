{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["**/.env.*local", "go.work", "go.work.sum"],
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "bin/**"],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*",
                "**/*.ts",
                "**/*.tsx",
                "**/*.go",
                "go.mod",
                "go.sum"
            ]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
